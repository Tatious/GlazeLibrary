# =============================================================================
# GlazeViewer Server Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3001
NODE_ENV=development

# Firebase Admin SDK (Required for authentication)
# Option 1: Place firebase-service-account.json in server/ directory (local dev)
# Option 2: Set this env var to the JSON content (Azure/production)
# Get the service account JSON from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# =============================================================================
# Azure Configuration (Production Only)
# =============================================================================
# These are only needed when deploying to Azure
# For local development, leave these commented out

# Azure Blob Storage
# Get this from: Azure Portal > Storage Account > Access Keys > Connection string
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=...;EndpointSuffix=core.windows.net

# Container name for storing user data and uploads (default: glaze-data)
# AZURE_STORAGE_CONTAINER=glaze-data

# Allowed CORS origins for production (comma-separated). REQUIRED when
# NODE_ENV=production — the server will refuse to start without it.
# ALLOWED_ORIGINS=https://your-app.azurewebsites.net,https://your-custom-domain.com
